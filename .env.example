# Copy this file to `.env` and set a strong, random token.
# The `.env` file is gitignored — never commit a real token.
#
# Generate one, e.g.:
#   openssl rand -base64 32
#
# Every SnipVault app that connects to this server must present this exact token.
SNIPVAULT_TOKEN=change-me-to-a-long-random-string
